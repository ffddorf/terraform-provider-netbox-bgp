{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:recommended"],
  packageRules: [
    {
      matchUpdateTypes: ["patch", "minor"],
      matchCategories: ["golang"],
      groupName: "Go modules",
      groupSlug: "golang",
    },
    {
      matchUpdateTypes: ["patch", "minor"],
      matchCategories: ["ci"],
      groupName: "CI helpers",
      groupSlug: "ci",
    },
  ],
  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: ["/^\\.github/workflows/.+\\.ya?ml$/"],
      matchStrings: [
        '# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)(\\s*extractVersion=(?<extractVersion>.*?))?\\s+\\S+_version:\\s*(-\\s+)?"(?<currentValue>\\S+)"',
      ],
    },
    {
      customType: "regex",
      managerFilePatterns: ["/docker-compose\\.ya?ml$/"],
      matchStrings: [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)\\s+\\S+_VERSION:\\s*(\\$\\{.+_VERSION:-)?(?<currentValue>[^\\s}]+)\\}?",
      ],
    },
  ],
}
